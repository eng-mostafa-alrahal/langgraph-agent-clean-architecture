{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python .cursor/hooks/session_install.py",
        "timeout": 300
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python .cursor/hooks/before_git_commit_sync.py",
        "matcher": "git\\s+commit(?:\\s|$)",
        "timeout": 60
      }
    ]
  }
}
