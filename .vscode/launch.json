{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (Run and Debug)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--reload",
        "--log-level",
        "debug",
        "--access-log"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug Worker (Celery)",
      "type": "python",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "workers.celery_app",
        "worker",
        "--loglevel=debug",
        "--pool=solo"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug Tests (Current File)",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Debug API + Worker",
      "configurations": [
        "Debug API (Run and Debug)",
        "Debug Worker (Celery)"
      ],
      "stopAll": true
    }
  ]
}
