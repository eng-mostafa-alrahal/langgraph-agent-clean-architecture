# Copy to `.env` and adjust values for your machine.
#
# ── MCP (optional): JSON array of MCP servers. See docs/architecture/mcp_integration.md
#
# Official filesystem MCP (reads/writes/creates files under ONE allowed directory).
# Requires Node.js so `npx` can download @modelcontextprotocol/server-filesystem.
#
# MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","mcp_workspace"]}]
