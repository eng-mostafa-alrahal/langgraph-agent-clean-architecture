# cp .env.example .env — full schema: app/core/config/settings.py

APP_NAME="LangGraph Agent System"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
WORKERS=1

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=agent_db
# DATABASE_URL=

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER_NAME=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
# REDIS_URL=

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

RATE_LIMIT_PER_MINUTE=60

OPENAI_API_KEY= 
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL_NAME=openai/gpt-oss-120b

AGENT_MAX_CONTEXT_TOKENS=12000
SUPERVISOR_ROUTING_MAX_TOKENS=2048
MAX_TOOL_OUTPUT_CHARS=10000
MEMORY_SUMMARIZATION_TRIGGER_MESSAGES=40
MEMORY_SUMMARIZATION_KEEP_RECENT_MESSAGES=12
MEMORY_SUMMARY_MAX_CHARS=4000
MEMORY_SUMMARIZER_PROVIDER=
MEMORY_SUMMARIZER_MODEL_NAME=

TAVILY_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
PGVECTOR_COLLECTION=knowledge_base
PGVECTOR_ENABLED=true

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langgraph-agents
OTEL_EXPORTER_ENDPOINT=

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

MCP_SERVERS=[]
# Official filesystem MCP (reads/writes/creates files under ONE allowed directory).
# Requires Node.js so `npx` can download @modelcontextprotocol/server-filesystem.
#
# MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","mcp_workspace"]}]
